# Docker Compose host-side variables.
# Copy to `.env` before running `docker compose`.

OPEN_STORY_HOST_DATA_DIR=/opt/open-story/data
OPEN_STORY_HOST_ASSETS_DIR=/opt/open-story/assets
OPEN_STORY_BUILD_NUMBER=local

# Prebuilt image references for `docker compose -f docker-compose.deploy.yml ...`
# Update these to the tags pushed by Cloud Build when using pull-based deploys.
# OPEN_STORY_API_IMAGE=gcr.io/open-story-493310/github.com/sezeryesiltas/open-story-api:<tag>
# OPEN_STORY_ADMIN_WEB_IMAGE=gcr.io/open-story-493310/github.com/sezeryesiltas/open-story-admin-web:<tag>
