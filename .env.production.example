# Node environment
NODE_ENV=production

# API server port (inside the container)
OPEN_STORY_API_PORT=3001

# SQLite database path (inside Docker volume)
OPEN_STORY_SQLITE_PATH=/data/open-story.sqlite

# Database config path (inside Docker volume)
OPEN_STORY_DB_CONFIG_PATH=/data/database-config.json

# Asset storage directory (inside Docker volume)
OPEN_STORY_ASSET_STORAGE_DIR=/data/assets

# Public base URL for asset files
# Replace <your-domain> with your actual domain or VM IP
OPEN_STORY_PUBLIC_ASSET_BASE_URL=https://<your-domain>/uploads/assets

# Admin Web → API connection (same container, use localhost)
OPEN_STORY_API_BASE_URL=http://localhost:3001

# Set to "false" when serving over HTTP (no HTTPS).
# When HTTPS is configured, remove this line or set to "true".
OPEN_STORY_COOKIE_SECURE=false
