# Shared runtime environment for Docker production services.
# API reads most variables here; admin-web mainly reads
# OPEN_STORY_API_BASE_URL and OPEN_STORY_COOKIE_SECURE.

# Node environment
NODE_ENV=production

# API server port (inside the container)
OPEN_STORY_API_PORT=3001

# Database resolution order: env -> config file.
# Production runtime requires Postgres; local SQLite fallback is only for non-production/test use.
# Config file path (inside container — mapped from host via bind mount)
OPEN_STORY_DB_CONFIG_PATH=/data/db/database-config.json

# Relational Postgres runtime database.
OPEN_STORY_POSTGRES_HOST=<postgres-host>
OPEN_STORY_POSTGRES_PORT=5432
OPEN_STORY_POSTGRES_DATABASE=postgres
OPEN_STORY_POSTGRES_USERNAME=postgres
OPEN_STORY_POSTGRES_PASSWORD=<postgres-password>
OPEN_STORY_POSTGRES_SSL_MODE=require

# Read cache TTL for Postgres-backed stores. Raise this for production to avoid
# repeated full feed snapshot reads under SDK traffic.
# OPEN_STORY_DB_READ_CACHE_TTL_MS=60000

# Asset storage resolution order: env -> config file -> local disk fallback.
# Config file path (inside container — mapped from host via bind mount)
OPEN_STORY_ASSET_STORAGE_CONFIG_PATH=/data/db/asset-storage-config.json

# Asset storage directory (inside container — mapped from host via bind mount)
OPEN_STORY_ASSET_STORAGE_DIR=/data/assets

# Compose-only host paths for bind mounts.
# These variables are consumed by docker-compose on the host; app code does not read them.
OPEN_STORY_HOST_DATA_DIR=/opt/open-story/data
OPEN_STORY_HOST_ASSETS_DIR=/opt/open-story/assets

# Public base URL for uploaded asset files.
# Must be browser-reachable and should usually be your public HTTPS domain.
OPEN_STORY_PUBLIC_ASSET_BASE_URL=https://<your-domain>/uploads/assets

# Optional Google Cloud Storage defaults for Storage & CDN settings.
# If these env vars are set, they override the config file values at runtime.
# Secrets are not stored in the admin DB; use Application Default Credentials,
# attached service accounts, or GOOGLE_APPLICATION_CREDENTIALS at runtime.
# OPEN_STORY_ASSET_STORAGE_PROVIDER=gcs
# OPEN_STORY_GCS_PROJECT_ID=<gcp-project-id>
# OPEN_STORY_GCS_BUCKET=<asset-bucket>
# OPEN_STORY_GCS_OBJECT_PREFIX=assets
# OPEN_STORY_GCS_PUBLIC_ASSET_BASE_URL=https://assets.<your-domain>
# OPEN_STORY_GCS_CACHE_CONTROL=public, max-age=31536000, immutable
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json

# Optional Supabase Storage S3 runtime override.
# OPEN_STORY_ASSET_STORAGE_PROVIDER=supabase_s3
# OPEN_STORY_SUPABASE_S3_ENDPOINT=https://project-ref.storage.supabase.co/storage/v1/s3
# OPEN_STORY_SUPABASE_S3_REGION=project_region
# OPEN_STORY_SUPABASE_S3_BUCKET=<asset-bucket>
# OPEN_STORY_SUPABASE_S3_ACCESS_KEY_ID=<access-key-id>
# OPEN_STORY_SUPABASE_S3_SECRET_ACCESS_KEY=<secret-access-key>
# OPEN_STORY_SUPABASE_S3_OBJECT_PREFIX=assets
# OPEN_STORY_SUPABASE_S3_PUBLIC_ASSET_BASE_URL=https://project-ref.supabase.co/storage/v1/object/public/<asset-bucket>
# OPEN_STORY_SUPABASE_S3_CACHE_CONTROL=public, max-age=31536000, immutable

# Admin Web -> API internal connection for Docker Compose.
OPEN_STORY_API_BASE_URL=http://api:3001

# Browser-facing admin cookie policy.
# Keep this enabled for HTTPS deployments (including HTTPS load balancers).
# Only set to "false" for plain local HTTP.
# OPEN_STORY_COOKIE_SECURE=true
